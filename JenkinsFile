pipeline {
    agent any
tools {
        maven 'LocalMaven'
    }

    options {
        skipStagesAfterUnstable()
    }
    stages {

        stage('Build') {
            steps {
                sh 'dotnet restore'
                sh 'dotnet build --no-restore'
            }
        }
	stage('Test') {
            steps {
                sh 'dotnet test --no-build --no-restore --collect "XPlat Code Coverage"'

            }
	   post {
                always {
                    recordCoverage(tools: [[parser: 'COBERTURA', pattern: '**/*.xml']], sourceDirectories: [[path: 'BookingWebsite.Test/TestResults']])
                }
            }

        }

stage('SonarQube Analysis') {
    steps {
        script {
            // Wrap variable assignments and logic in a script block
            def scannerHome = tool 'SonarScanner for .NET'
            
            // Provide the name of your SonarQube server as configured in Jenkins
            withSonarQubeEnv('SonarQube') { 
                // Your analysis commands here, for example:
                sh "${scannerHome}/dotnet-sonarscanner begin /k:\"ProjectKey\""
                sh "dotnet build"
                sh "${scannerHome}/dotnet-sonarscanner end"
            }
        }
    }
}
        stage('Deliver') { 
            steps {
                sh 'dotnet publish BookingWebsite --no-restore -o published'  
            }
            post {
                success {
                    archiveArtifacts 'published/*.*' 
                }
            }
        }
    }
}

