pipeline {
    agent any
    options {
        skipStagesAfterUnstable()
    }
    stages {

        stage('Build') {
            steps {
                sh 'dotnet restore'
                sh 'dotnet build --no-restore'
            }
        }
	stage('SonarQube Analysis') {
            steps {
                script {
            // Wrapping in script {} allows variable definitions
            def scannerHome = tool 'sonar-scanner'
            
            withSonarQubeEnv('SonarQube') {
                sh "${scannerHome}/bin/sonar-scanner \
                -Dsonar.projectKey=BookingWebsite \
                -Dsonar.sources=."
            }
        }
        }
	stage('Test') {
            steps {
                sh 'dotnet test --no-build --no-restore --collect "XPlat Code Coverage"'

            }
	   post {
                always {
                    recordCoverage(tools: [[parser: 'COBERTURA', pattern: '**/*.xml']], sourceDirectories: [[path: 'BookingWebsite.Test/TestResults']])
                }
            }

        }

        stage('Deliver') { 
            steps {
                sh 'dotnet publish BookingWebsite --no-restore -o published'  
            }
            post {
                success {
                    archiveArtifacts 'published/*.*' 
                }
            }
        }
    }
}