pipeline {
    agent any
tools {
        maven 'LocalMaven'
    }

    options {
        skipStagesAfterUnstable()
    }
    stages {

        stage('Build') {
            steps {
                sh 'dotnet restore'
                sh 'dotnet build --no-restore'
            }
        }
	stage('Test') {
            steps {
                sh 'dotnet test --no-build --no-restore --collect "XPlat Code Coverage"'

            }
	   post {
                always {
                    recordCoverage(tools: [[parser: 'COBERTURA', pattern: '**/*.xml']], sourceDirectories: [[path: 'BookingWebsite.Test/TestResults']])
                }
            }

        }

stage('SonarQube Analysis') {
    steps {
        script {
            // Ensure the tool is available
            sh 'dotnet tool install --global dotnet-sonarscanner || true'
            
            withEnv(["PATH+SONAR=/${env.HOME}/.dotnet/tools"]) {
                // withSonarQubeEnv injects SONAR_HOST_URL and credentials automatically
                withSonarQubeEnv('SonarQube') {
                    sh 'dotnet sonarscanner begin /k:"ProjectKey" /d:sonar.host.url="${SONAR_HOST_URL}" /d:sonar.login="${SONAR_AUTH_TOKEN}"'
                    sh 'dotnet build'
                    sh 'dotnet sonarscanner end /d:sonar.login="${SONAR_AUTH_TOKEN}"'
                }
            }
        }
    }
}
        stage('Deliver') { 
            steps {
                sh 'dotnet publish BookingWebsite --no-restore -o published'  
            }
            post {
                success {
                    archiveArtifacts 'published/*.*' 
                }
            }
        }
    }
}

