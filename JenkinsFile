pipeline {
    agent any
    options {
        skipStagesAfterUnstable()
    }
    stages {
        stage('Build') {
            steps {
                sh 'dotnet restore'
                sh 'dotnet build --no-restore'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    // This matches the tool name in Jenkins -> Global Tool Configuration
                    def scannerHome = tool 'sonar-scanner'
                    
                    withSonarQubeEnv('SonarQube') {
                        sh "${scannerHome}/bin/sonar-scanner \
                            -Dsonar.projectKey=BookingWebsite \
                            -Dsonar.sources=. \
                            -Dsonar.host.url=${SONAR_HOST_URL} \
                            -Dsonar.login=${SONAR_AUTH_TOKEN}"
                    }
                }
            }
        }

        stage('Test') {
            steps {
                sh 'dotnet test --no-build --no-restore --collect "XPlat Code Coverage"'
            }
            post {
                always {
                    // Ensure the 'recordCoverage' step plugin is installed in Jenkins
                    recordCoverage(tools: [[parser: 'COBERTURA', pattern: '**/TestResults/**/coverage.cobertura.xml']], sourceDirectories: [[path: 'BookingWebsite.Test/']])
                }
            }
        }

        stage('Deliver') { 
            steps {
                sh 'dotnet publish BookingWebsite --no-restore -o published'  
            }
            post {
                success {
                    archiveArtifacts artifacts: 'published/**/*', fingerprint: true
                }
            }
        }
    }
}