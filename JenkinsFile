pipeline {
    agent any
tools {
        maven 'LocalMaven'
    }

    options {
        skipStagesAfterUnstable()
    }
    stages {

        stage('Build') {
            steps {
                sh 'dotnet restore'
                sh 'dotnet build --no-restore'
            }
        }
	stage('Test') {
            steps {
                sh 'dotnet test --no-build --no-restore --collect "XPlat Code Coverage"'

            }
	   post {
                always {
                    recordCoverage(tools: [[parser: 'COBERTURA', pattern: '**/*.xml']], sourceDirectories: [[path: 'BookingWebsite.Test/TestResults']])
                }
            }

        }

stage('SonarQube Analysis') {
    steps {
        script {
            // 1. Ensure the scanner tool is installed in the current environment
            // You can also do this once in your Dockerfile or agent setup
            sh 'dotnet tool install --global dotnet-sonarscanner || true'
            
            // 2. Add the global tools path to your PATH so Jenkins can find it
            // Typically located at ~/.dotnet/tools
            withEnv(["PATH+SONAR=/${env.HOME}/.dotnet/tools"]) {
                withSonarQubeEnv('SonarQube') {
                    sh 'dotnet sonarscanner begin /k:"ProjectKey" /d:sonar.token="${SONAR_TOKEN}"'
                    sh 'dotnet build'
                    sh 'dotnet sonarscanner end /d:sonar.token="${SONAR_TOKEN}"'
                }
            }
        }
    }
}
        stage('Deliver') { 
            steps {
                sh 'dotnet publish BookingWebsite --no-restore -o published'  
            }
            post {
                success {
                    archiveArtifacts 'published/*.*' 
                }
            }
        }
    }
}

