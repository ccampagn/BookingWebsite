pipeline {
    agent any
    options {
        skipStagesAfterUnstable()
    }
    stages {
	stage('Clean Workspace') {
    steps {
        // This deletes all old test results so Jenkins can't find old data
        sh 'rm -rf **/TestResults'
        sh 'rm -rf **/coverage-results'
    }
}
        stage('Build') {
            steps {
                sh 'dotnet restore'
                sh 'dotnet build --no-restore'
            }
        }
	stage('Test') {
            steps {
                sh 'dotnet test --no-build --no-restore \
  --collect:"XPlat Code Coverage" \
  --results-directory ./coverage-results \
  -- DataCollectionRunSettings.DataCollectors.DataCollector.Configuration.Format=cobertura'

            }
	   post {
                always {
                    recordCoverage(tools: [[parser: 'COBERTURA', pattern: 'coverage-results/**/*.xml']])
                }
            }

        }

        stage('Deliver') { 
            steps {
                sh 'dotnet publish BookingWebsite --no-restore -o published'  
            }
            post {
                success {
                    archiveArtifacts 'published/*.*' 
                }
            }
        }
    }
}